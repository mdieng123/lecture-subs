{
  "name": "lecture-subs",
  "version": "0.1.0",
  "description": "Arabic lecture to English subtitles desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "npm run build && npm run electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json",
    "postinstall": "node scripts/download-ytdlp.mjs"
  },
  "dependencies": {
    "@google/genai": "1.10.0",
    "electron-store": "10.0.1",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "3.1.0",
    "fluent-ffmpeg": "2.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-window": "1.8.10",
    "uuid": "11.0.3",
    "wavesurfer.js": "7.8.6",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@types/ffprobe-static": "2.0.3",
    "@types/fluent-ffmpeg": "2.1.27",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/react-window": "1.8.8",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.0",
    "electron": "41.2.1",
    "electron-builder": "26.9.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vite": "6.4.2",
    "vite-plugin-electron": "0.28.8",
    "vite-plugin-electron-renderer": "0.14.6"
  },
  "build": {
    "appId": "com.lecturesubs.app",
    "productName": "LectureSubs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!landing-page/**"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": ["yt-dlp", "yt-dlp.exe"]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
